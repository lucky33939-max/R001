# 4) Tạo 2 menu riêng: `+888` và `VIP Bot`

## Dán tiếp vào phần `UI HELPERS`

```python
async def send_vip_888(target, lang: str):
    category = await find_category_by_name_en("Nice Numbers & Anonymous")
    if not category:
        if isinstance(target, Message):
            await target.answer(t(lang, "no_services"))
        else:
            await safe_edit(target, t(lang, "no_services"))
        return

    rows = await list_services_by_category(category["id"])
    rows = [
        r for r in rows
        if (
            "888" in r["title"]
            or "Anonymous" in r["title"]
            or "Private" in r["title"]
            or "Prestige" in r["title"]
            or "Number" in r["title"]
        )
    ]

    if not rows:
        if isinstance(target, Message):
            await target.answer(t(lang, "no_services"))
        else:
            await safe_edit(target, t(lang, "no_services"))
        return

    kb = InlineKeyboardBuilder()
    for row in rows:
        kb.button(
            text=f"👑 {row['title']} - {float(row['price']):.2f} USDT",
            callback_data=f"service:{row['id']}"
        )
    kb.button(text=t(lang, "back_menu"), callback_data="menu")
    kb.adjust(1)

    if isinstance(target, Message):
        await target.answer(t(lang, "vip_888_title"), reply_markup=kb.as_markup())
    else:
        await safe_edit(target, t(lang, "vip_888_title"), reply_markup=kb.as_markup())


async def send_vip_bots(target, lang: str):
    cat_bot = await find_category_by_name_en("VIP Bot Suites")
