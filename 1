## Thêm các hàm này vào cuối `db.py`

```python
async def add_to_cart(tg_id: int, service_id: int):
    async with db_pool.acquire() as conn:
        service = await conn.fetchrow("""
            SELECT id FROM services
            WHERE id = $1 AND active = TRUE
        """, service_id)

        if not service:
            return False, "service_not_found"

        exists = await conn.fetchrow("""
            SELECT id FROM cart_items
            WHERE telegram_id = $1 AND service_id = $2
        """, tg_id, service_id)

        if exists:
            return False, "already_in_cart"

        await conn.execute("""
            INSERT INTO cart_items (telegram_id, service_id)
            VALUES ($1, $2)
        """, tg_id, service_id)

        return True, "added_to_cart"


async def get_cart_items(tg_id: int):
    async with db_pool.acquire() as conn:
        return await conn.fetch("""
            SELECT c.service_id, c.created_at, s.title, s.price, s.badge
            FROM cart_items c
            JOIN services s ON s.id = c.service_id
            WHERE c.telegram_id = $1 AND s.active = TRUE
            ORDER BY c.id ASC
        """, tg_id)


async def remove_from_cart(tg_id: int, service_id: int):
    async with db_pool.acquire() as conn:
        result = await conn.execute("""
            DELETE FROM cart_items
            WHERE telegram_id = $1 AND service_id = $2
        """, tg_id, service_id)
        return result.endswith("1")


async def clear_cart(tg_id: int):
    async with db_pool.acquire() as conn:
        await conn.execute("""
            DELETE FROM cart_items
            WHERE telegram_id = $1
        """, tg_id)


async def get_cart_total(tg_id: int):
    async with db_pool.acquire() as conn:
        row = await conn.fetchrow("""
            SELECT COALESCE(SUM(s.price), 0) AS total
            FROM cart_items c
            JOIN services s ON s.id = c.service_id
            WHERE c.telegram_id = $1 AND s.active = TRUE
        """, tg_id)
        return float(row["total"]) if row else 0.0


async def checkout_cart(tg_id: int):
    async with db_pool.acquire() as conn:
        async with conn.transaction():
            user = await conn.fetchrow("""
                SELECT * FROM users
                WHERE telegram_id = $1
                FOR UPDATE
            """, tg_id)

            if not user:
                return False, "service_not_found"

            items = await conn.fetch("""
                SELECT c.service_id, s.title, s.price
                FROM cart_items c
                JOIN services s ON s.id = c.service_id
                WHERE c.telegram_id = $1 AND s.active = TRUE
                ORDER BY c.id ASC
            """, tg_id)

            if not items:
                return False, "cart_empty"

            total = sum((item["price"] for item in items), Decimal("0"))

            if Decimal(str(user["balance"])) < total:
                return False, "balance_not_enough"

            await conn.execute("""
                UPDATE users
                SET balance = balance - $1,
                    total_spent = total_spent + $1
                WHERE telegram_id = $2
            """, total, tg_id)

            order_ids = []
            titles = []

            for item in items:
                row = await conn.fetchrow("""
                    INSERT INTO orders (telegram_id, service_id, price, status)
                    VALUES ($1, $2, $3, 'paid')
                    RETURNING id
                """, tg_id, item["service_id"], item["price"])

                order_ids.append(row["id"])
                titles.append(item["title"])

            await conn.execute("""
                DELETE FROM cart_items
                WHERE telegram_id = $1
            """, tg_id)

            return True, {
                "count": len(items),
                "total": float(total),
                "order_ids": order_ids,
                "titles": titles
            }
```

