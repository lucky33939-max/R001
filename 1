# 8) Thêm callback cho giỏ hàng

Dán vào phần `CALLBACK HANDLERS`:

```python
@dp.callback_query(F.data.startswith("addcart:"))
async def cb_addcart(call: CallbackQuery):
    await get_or_create_user_from_tg(call.from_user)
    lang = await get_user_lang(call.from_user.id)
    service_id = int(call.data.split(":")[1])

    ok, result = await add_to_cart(call.from_user.id, service_id)
    if not ok:
        await call.answer(t(lang, result), show_alert=True)
        return

    await call.answer(t(lang, "added_to_cart"), show_alert=True)


@dp.callback_query(F.data.startswith("cart_remove:"))
async def cb_cart_remove(call: CallbackQuery):
    lang = await get_user_lang(call.from_user.id)
    service_id = int(call.data.split(":")[1])

    await remove_from_cart(call.from_user.id, service_id)
    await call.answer(t(lang, "removed_from_cart"))
    await send_cart(call, lang, call.from_user.id)


@dp.callback_query(F.data == "cart_clear")
async def cb_cart_clear(call: CallbackQuery):
    lang = await get_user_lang(call.from_user.id)
    await clear_cart(call.from_user.id)
    await call.answer("OK")
    await safe_edit(call, t(lang, "cart_empty"), reply_markup=back_to_menu_inline(lang))


@dp.callback_query(F.data == "cart_checkout")
async def cb_cart_checkout(call: CallbackQuery):
    await get_or_create_user_from_tg(call.from_user)
    lang = await get_user_lang(call.from_user.id)

    ok, result = await checkout_cart(call.from_user.id)
    if not ok:
        if result == "balance_not_enough":
            await call.answer(t(lang, "balance_not_enough"), show_alert=True)
            await call.message.answer(t(lang, "topup_title"), reply_markup=topup_kb(lang))
            return

        await call.answer(t(lang, result), show_alert=True)
        return

    order_ids_text = ", ".join([f"#{x}" for x in result["order_ids"]])

    kb = InlineKeyboardMarkup(
        inline_keyboard=[
            [InlineKeyboardButton(text=t(lang, "btn_invoice"), callback_data="invoice_list")],
            [InlineKeyboardButton(text=t(lang, "contact_support"), url=SUPPORT_LINK)],
            [InlineKeyboardButton(text=t(lang, "back_menu"), callback_data="menu")]
        ]
    )

    await call.message.answer(
        t(
            lang,
            "checkout_success",
            count=result["count"],
            total=result["total"],
            order_ids=order_ids_text
        ),
        reply_markup=kb
    )

    if ADMIN_ID:
        try:
            titles = "\n".join([f"- {x}" for x in result["titles"]])
            await bot.send_message(
                ADMIN_ID,
                f"🛒 New cart checkout\n"
                f"User: {call.from_user.full_name} ({call.from_user.id})\n"
                f"Items: {result['count']}\n"
                f"Total: {result['total']:.2f} USDT\n"
                f"Orders: {order_ids_text}\n\n"
                f"{titles}"
            )
        except Exception:
            pass

    await call.answer("OK")
```

