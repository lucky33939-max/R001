# 6) Thêm hàm hiển thị giỏ hàng

Dán vào phần `UI HELPERS` trong `bot.py`:

```python
async def send_cart(target, lang: str, tg_id: int):
    rows = await get_cart_items(tg_id)
    if not rows:
        if isinstance(target, Message):
            await target.answer(t(lang, "cart_empty"))
        else:
            await safe_edit(target, t(lang, "cart_empty"), reply_markup=back_to_menu_inline(lang))
        return

    text = t(lang, "cart_title")
    for row in rows:
        text += t(
            lang,
            "cart_line",
            title=row["title"],
            price=float(row["price"])
        )

    total = await get_cart_total(tg_id)
    text += t(lang, "cart_total", total=total)

    kb = InlineKeyboardBuilder()

    for row in rows:
        kb.button(
            text=f"{t(lang, 'cart_remove')} {row['title'][:30]}",
            callback_data=f"cart_remove:{row['service_id']}"
        )

    kb.button(text=t(lang, "cart_checkout"), callback_data="cart_checkout")
    kb.button(text=t(lang, "cart_clear"), callback_data="cart_clear")
    kb.button(text=t(lang, "back_menu"), callback_data="menu")
    kb.adjust(1)

    if isinstance(target, Message):
        await target.answer(text, reply_markup=kb.as_markup())
    else:
        await safe_edit(target, text, reply_markup=kb.as_markup())
```

